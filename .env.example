# BCET ATR System — Environment Variables
# Copy this to .env.local and fill in the values
# NEVER commit .env.local to git

# MongoDB Atlas connection string
# Replace YOUR_PASSWORD with your actual bcetsih2025_db_user password
MONGODB_URI=mongodb+srv://bcetsih2025_db_user:YOUR_PASSWORD@atr.6zfeqvp.mongodb.net/bcet_atr?appName=ATR

# JWT signing secret — generate a strong random string (min 32 chars)
# Example: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=bcet-atr-super-secret-please-change-before-production-deploy-2025
